# Gmail SMTP Configuration for yugamgroup.com Contact Form
#
# Instructions:
# 1. Copy this file and rename it to .env (remove .example)
# 2. Fill in your Gmail credentials below
# 3. Add .env to your .gitignore file (don't commit credentials to git!)
# 4. Never share this file publicly

# Your Gmail address (the account sending emails)
GMAIL_USER=yugamsale@gmail.com

# Your 16-character App Password from Gmail
# Generate at: myaccount.google.com → Security → App passwords
# Format: xxxx xxxx xxxx xxxx (with spaces)
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Recipient email for contact form submissions
SALES_EMAIL=sales@yugamgroup.com

# Server port
PORT=3000

# Environment (development or production)
NODE_ENV=production
