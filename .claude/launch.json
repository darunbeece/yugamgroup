{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Node.js Server (with Email)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["start"],
      "port": 3000
    },
    {
      "name": "Python HTTP Server",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8000"],
      "port": 8000
    },
    {
      "name": "Docker Compose",
      "runtimeExecutable": "docker-compose",
      "runtimeArgs": ["up"],
      "port": 8080
    }
  ]
}
